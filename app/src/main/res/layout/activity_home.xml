<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#1A1A2E">

    <ImageView
        android:id="@+id/ivHomeLock"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_lock"
        android:contentDescription="SafeKid" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="SafeKid"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Control Parental"
        android:textColor="#B0B0B0"
        android:textSize="16sp" />

    <View
        android:layout_width="200dp"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="#333355" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Tiempo restante hoy"
        android:textColor="#B0B0B0"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvHomeRemainingTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="--"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHomeStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="#B0B0B0"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnAdminAccess"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Acceso administrador"
        android:backgroundTint="#FF6200EE"
        android:paddingLeft="32dp"
        android:paddingRight="32dp"
        android:textColor="#FFFFFF" />

</LinearLayout>
