<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Panel de padres"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvParentUsername"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/tvParentStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Cargando hijos..."
        android:textSize="16sp" />

    <ListView
        android:id="@+id/lvChildren"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="Comparte tu código con los hijos para que se vinculen al registrarse"
        android:textSize="12sp"
        android:textColor="#999999" />

    <Button
        android:id="@+id/btnParentSettings"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="Configuración del dispositivo" />

    <Button
        android:id="@+id/btnLogoutParent"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#FF4444"
        android:text="Cerrar sesión" />

</LinearLayout>
