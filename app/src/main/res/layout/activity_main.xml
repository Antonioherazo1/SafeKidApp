<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:id="@+id/blockImage"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_lock"
            android:contentDescription="Icono de bloqueo" />

        <TextView
            android:id="@+id/tvBlockTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Dispositivo bloqueado"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvBlockReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#FF5252"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvBlockSchedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#F59E0B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvBlockMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Toca 5 veces para desbloquear"
            android:textColor="#8B949E"
            android:textSize="16sp" />

        <View
            android:layout_width="64dp"
            android:layout_height="2dp"
            android:layout_marginTop="48dp"
            android:background="#21262D" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="SafeKid"
            android:textColor="#484F58"
            android:textSize="14sp" />

    </LinearLayout>

</FrameLayout>
